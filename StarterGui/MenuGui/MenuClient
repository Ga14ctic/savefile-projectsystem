------------------------------------------------------------------------
-- REFRESH SKILL TREE
------------------------------------------------------------------------

-- Which move is selected for equipping
local selectedMove = nil

function RefreshSkillTree()
	cachedData = GetSkillData:InvokeServer()
	if not cachedData then return end

	-- Update points display
	pointsLabel.Text = "Points: " .. (cachedData.SkillPoints or 0)

	local treeKeys = {"StrengthPoints", "DexterityPoints", "MasteryPoints"}

	for i, tree in ipairs(SkillTreeConfig.Trees) do
		local col = treeColumns[i]
		local pointsInTree = cachedData[treeKeys[i]] or 0

		-- Update header points
		col.TreePointsLabel.Text = pointsInTree .. " pts"

		-- Update + button visibility
		if (cachedData.SkillPoints or 0) > 0 then
			col.AddBtn.BackgroundTransparency = 0.4
		else
			col.AddBtn.BackgroundTransparency = 0.8
		end

		-- Clear old moves
		for _, child in ipairs(col.MoveList:GetChildren()) do
			if child:IsA("TextButton") then
				child:Destroy()
			end
		end

		-- Add moves
		for moveIndex, move in ipairs(tree.Moves) do
			local isUnlocked = pointsInTree >= move.PointsRequired

			-- Check if equipped
			local equippedSlot = nil
			for slot, name in pairs(cachedData.EquippedMoves or {}) do
				if name == move.Name then
					equippedSlot = tonumber(slot)
					break
				end
			end

			local moveBtn = Create("TextButton", {
				Name = "Move_" .. moveIndex,
				Size = UDim2.new(1, 0, 0, 26),
				BackgroundTransparency = 1,
				Text = "",
				LayoutOrder = moveIndex,
				Parent = col.MoveList,
			})

			-- Move text with color coding
			local displayText = move.Name
			if not isUnlocked then
				displayText = move.Name .. " - " .. move.PointsRequired
			end

			local textColor
			if not isUnlocked then
				textColor = Color3.fromRGB(80, 80, 90) -- greyed out
			elseif equippedSlot then
				textColor = Color3.fromRGB(255, 220, 80) -- gold = equipped
			else
				textColor = Color3.fromRGB(220, 220, 230) -- white = unlocked
			end

			Create("TextLabel", {
				Size = UDim2.new(1, -10, 1, 0),
				Position = UDim2.new(0, 8, 0, 0),
				BackgroundTransparency = 1,
				Text = displayText,
				TextColor3 = textColor,
				TextSize = 13,
				Font = Enum.Font.Gotham,
				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = moveBtn,
			})

			-- Slot indicator if equipped
			if equippedSlot then
				Create("TextLabel", {
					Size = UDim2.new(0, 20, 1, 0),
					Position = UDim2.new(1, -25, 0, 0),
					BackgroundTransparency = 1,
					Text = tostring(HOTBAR_KEYS[equippedSlot].Display),
					TextColor3 = Color3.fromRGB(255, 220, 80),
					TextSize = 11,
					Font = Enum.Font.GothamBold,
					TextXAlignment = Enum.TextXAlignment.Right,
					Parent = moveBtn,
				})
			end

			-- Click behavior
			if isUnlocked then
				moveBtn.MouseButton1Click:Connect(function()
					if equippedSlot then
						-- Already equipped, unequip it
						EquipMoveRemote:FireServer("", equippedSlot)
						task.wait(0.2)
						RefreshSkillTree()
						RefreshHotbar()
					else
						-- Select this move, wait for slot click
						selectedMove = move.Name
						instructionLabel.Text = "Now click a hotbar slot for: " .. move.Name
						instructionLabel.TextColor3 = Color3.fromRGB(255, 220, 80)
					end
				end)

				-- Hover effect
				moveBtn.MouseEnter:Connect(function()
					moveBtn.BackgroundTransparency = 0.85
					moveBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
				end)
				moveBtn.MouseLeave:Connect(function()
					moveBtn.BackgroundTransparency = 1
				end)
			end
		end

		-- Update canvas size
		col.MoveList.CanvasSize = UDim2.new(0, 0, 0, col.MoveLayout.AbsoluteContentSize.Y + 10)
	end

	-- Also refresh hotbar
	RefreshHotbar()
end

------------------------------------------------------------------------
-- HOTBAR SLOT CLICK → EQUIP SELECTED MOVE
------------------------------------------------------------------------

for i, slotData in ipairs(hotbarSlots) do
	local clickBtn = slotData.Frame:FindFirstChild("ClickBtn")
	if clickBtn then
		clickBtn.MouseButton1Click:Connect(function()
			if selectedMove and skillTreeOpen then
				EquipMoveRemote:FireServer(selectedMove, i)
				selectedMove = nil
				assigningSlot = nil
				instructionLabel.Text = "Click a move to equip → then click a hotbar slot"
				instructionLabel.TextColor3 = Color3.fromRGB(80, 80, 90)
				RefreshHotbarHighlight()
				task.wait(0.2)
				RefreshSkillTree()
			end
		end)
	end
end

