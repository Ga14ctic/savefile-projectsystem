------------------------------------------------------------------------
-- HOTBAR TAP/KEY ACTIVATION
------------------------------------------------------------------------

-- This fires when a player taps a hotbar slot (mobile) or presses a key (PC)
-- The actual move execution will be handled by the combat system later
local HotbarActivated = Instance.new("BindableEvent")
HotbarActivated.Name = "HotbarActivated"
HotbarActivated.Parent = ReplicatedStorage

for i, slotData in ipairs(hotbarSlots) do
	local clickBtn = slotData.Frame:FindFirstChild("ClickBtn")
	if clickBtn then
		clickBtn.MouseButton1Click:Connect(function()
			-- Only activate if skill tree is NOT open (otherwise we're equipping)
			if not skillTreeOpen and slotData.MoveName and slotData.MoveName ~= "" then
				HotbarActivated:Fire(i, slotData.MoveName)
				print("[Hotbar] Activated slot " .. i .. ": " .. slotData.MoveName)
			end
		end)
	end
end

-- PC keyboard activation
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if skillTreeOpen or menuOpen then return end

	for i, keyInfo in ipairs(HOTBAR_KEYS) do
		if input.KeyCode == keyInfo.Key then
			local slotData = hotbarSlots[i]
			if slotData.MoveName and slotData.MoveName ~= "" then
				HotbarActivated:Fire(i, slotData.MoveName)
				print("[Hotbar] Activated slot " .. i .. ": " .. slotData.MoveName)
			end
			break
		end
	end
end)

------------------------------------------------------------------------
-- HOTBAR REFRESH
------------------------------------------------------------------------

local function RefreshHotbar()
	cachedData = GetSkillData:InvokeServer()
	if not cachedData then return end

	local equipped = cachedData.EquippedMoves or {}

	for i = 1, 12 do
		local slotData = hotbarSlots[i]
		local moveName = equipped[tostring(i)] or ""
		slotData.MoveName = moveName

		if moveName ~= "" then
			slotData.MoveLabel.Text = moveName
			slotData.Frame.BackgroundColor3 = Color3.fromRGB(28, 28, 40)
		else
			slotData.MoveLabel.Text = ""
			slotData.Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
		end
	end
end

function RefreshHotbarHighlight()
	for i, slotData in ipairs(hotbarSlots) do
		local stroke = slotData.Frame:FindFirstChildOfClass("UIStroke")
		if stroke then
			if assigningSlot == i then
				stroke.Color = Color3.fromRGB(255, 220, 60)
				stroke.Thickness = 2
			else
				stroke.Color = Color3.fromRGB(55, 55, 70)
				stroke.Thickness = 1.5
			end
		end
	end
end

