--[[
    LeaderboardClient (LocalScript)
    TAB toggle leaderboard.
    
    Shows:
        Sylphie Monarch          ← name + clan (white)
        Hunter                   ← official guild title (guild color)
        [DRAGONS]                ← unofficial guild tag (yellow in white brackets)
    
    Hover shows @username.
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer

local screenGui = script.Parent

StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, false)

------------------------------------------------------------------------
-- HELPERS
------------------------------------------------------------------------

local function Create(className, properties)
	local instance = Instance.new(className)
	for prop, value in pairs(properties) do
		instance[prop] = value
	end
	return instance
end

------------------------------------------------------------------------
-- TOOLTIP
------------------------------------------------------------------------

local tooltip = Create("TextLabel", {
	Name = "Tooltip",
	Size = UDim2.new(0, 0, 0, 22),
	AutomaticSize = Enum.AutomaticSize.X,
	BackgroundColor3 = Color3.fromRGB(20, 20, 28),
	BackgroundTransparency = 0.1,
	Text = "",
	TextColor3 = Color3.fromRGB(160, 160, 170),
	TextSize = 12,
	Font = Enum.Font.Gotham,
	Visible = false,
	ZIndex = 10,
	Parent = screenGui,
})

Create("UICorner", {CornerRadius = UDim.new(0, 4), Parent = tooltip})
Create("UIPadding", {PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8), Parent = tooltip})
Create("UIStroke", {Color = Color3.fromRGB(50, 50, 65), Thickness = 1, Parent = tooltip})

------------------------------------------------------------------------
-- CONTAINER
------------------------------------------------------------------------

local container = Create("Frame", {
	Name = "LeaderboardContainer",
	Size = UDim2.new(0, 280, 0, 0),
	Position = UDim2.new(1, -290, 0, 10),
	BackgroundTransparency = 1,
