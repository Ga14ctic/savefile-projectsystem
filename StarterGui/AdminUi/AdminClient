--[[
    AdminClient (LocalScript)
    F2 to toggle admin command line.
    Shows autocomplete dropdown as you type.
    
    Format: command [player] [value]
    Example: clan bsbvuufqy Monarch
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local AdminConfig = require(ReplicatedStorage:WaitForChild("AdminConfig"))
local Remotes = ReplicatedStorage:WaitForChild("Remotes")

local screenGui = script.Parent
local isAdmin = false
local panelOpen = false

------------------------------------------------------------------------
-- CHECK ADMIN STATUS
------------------------------------------------------------------------

task.spawn(function()
	local AdminCheck = Remotes:WaitForChild("AdminCheck", 10)
	if AdminCheck then
		local success, result = pcall(function()
			return AdminCheck:InvokeServer()
		end)
		if success then
			isAdmin = result
		end
	end

	if not isAdmin then
		screenGui.Enabled = false
		print("[AdminPanel] Not an admin. Panel disabled.")
	else
		print("[AdminPanel] Admin verified. Press F2 to open.")
	end
end)

